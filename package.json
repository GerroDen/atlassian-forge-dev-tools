{
  "name": "atlassian-forge-dev-tools",
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite build --mode development",
    "generate-tokens": "vite-node -c vite.node.config.ts unocss/chrome-dev-tools-tokens-generate.ts",
