    "lint-staged": "^16.4.0",
    "npm-run-all-next": "^1.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "unocss": "^66.1.2",
    "vite": "^8.0.10",
    "vite-node": "^6.0.0",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-oxlint": "^2.1.1",
    "vite-plugin-web-extension": "^4.5.1",
    "vue-tsc": "^3.2.8",
    "web-ext": "^10.1.0"
